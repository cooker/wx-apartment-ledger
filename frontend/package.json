{
  "name": "wx-apartment-ledger-frontend",
  "version": "0.0.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "vite build --mode electron",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build:electron && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.wx.apartment.ledger",
    "productName": "房屋租赁管理",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["zh_CN"],
      "shortcutName": "房屋租赁管理"
    }
  }
}
